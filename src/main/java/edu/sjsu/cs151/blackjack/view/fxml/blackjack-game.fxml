<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="15" alignment="CENTER"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="edu.sjsu.cs151.blackjack.controller.BlackjackGameController">

    <Label fx:id="turnLabel" text="Current Turn: Waiting for bet" />

    <VBox fx:id="dealerBox" spacing="5" alignment="CENTER">
        <Label text="Dealer" />
        <Label fx:id="dealerMoneyLabel" text="Dealer" />
        <HBox fx:id="dealerCardsBox" spacing="5" alignment="CENTER" />
    </VBox>

    <HBox spacing="40" alignment="CENTER">
        <VBox fx:id="playerOneBox" spacing="5" alignment="CENTER">
            <Label text="Player 1" />
            <Label fx:id="playerOneMoneyLabel" text="Money: $1000" />
            <HBox fx:id="playerOneCardsBox" spacing="5" alignment="CENTER" />
        </VBox>

        <VBox fx:id="playerTwoBox" spacing="5" alignment="CENTER">
            <Label text="Player 2" />
            <Label fx:id="playerTwoMoneyLabel" text="Money: $1000" />
            <HBox fx:id="playerTwoCardsBox" spacing="5" alignment="CENTER" />
        </VBox>
    </HBox>

    <VBox fx:id="humanBox" spacing="5" alignment="CENTER">
        <Label text="You" />
        <Label fx:id="humanMoneyLabel" text="Money: $1000" />
        <HBox fx:id="humanCardsBox" spacing="5" alignment="CENTER" />
    </VBox>

    <HBox spacing="10" alignment="CENTER">
        <TextField fx:id="betField" promptText="Enter bet amount" />
        <Button fx:id="betButton" text="Place Bet" />
    </HBox>

    <HBox spacing="10" alignment="CENTER">
        <Button fx:id="hitButton" text="Hit" />
        <Button fx:id="standButton" text="Stand" />
    </HBox>

    <Label fx:id="statusLabel" text="Place a bet to start." />

</VBox>
