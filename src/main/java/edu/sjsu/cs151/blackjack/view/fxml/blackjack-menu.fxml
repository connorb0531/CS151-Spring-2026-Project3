<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="15" alignment="CENTER"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="edu.sjsu.cs151.blackjack.controller.BlackjackMenuController">

    <Label text="Blackjack Menu" />

    <Button fx:id="startButton" text="Start New Game" />

    <Label text="Load Game" />
    <TextArea fx:id="saveStateInput" promptText="Enter saveStateString here" prefRowCount="4" />

    <Button fx:id="loadButton" text="Load Game" />

</VBox>